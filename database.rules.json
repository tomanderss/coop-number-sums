{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && $code.matches(/^[0-9]{6}$/)",

        "meta": {
          ".validate": "newData.hasChildren(['hostId','createdAt','status'])"
        },

        "players": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.hasChildren(['name','color','role','joinedAt'])"
          }
        },

        "events": {
          "$eventId": {
            ".validate": "newData.hasChildren(['type','author','ts']) && newData.child('author').val() === auth.uid"
          }
        },

        "teamEvents": {
          "$team": {
            "$eventId": {
              ".validate": "newData.hasChildren(['type','author','ts']) && newData.child('author').val() === auth.uid && ($team === 'A' || $team === 'B')"
            }
          }
        },

        "teamProgress": {
          "$team": {
            ".write": "auth != null",
            ".validate": "newData.hasChildren(['pct','mistakes']) && newData.child('pct').isNumber() && newData.child('mistakes').isNumber() && ($team === 'A' || $team === 'B')"
          }
        },

        "raceProgress": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".validate": "newData.hasChildren(['pct','mistakes']) && newData.child('pct').isNumber() && newData.child('mistakes').isNumber()"
          }
        }
      }
    },

    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin')",
        "profile": {
          "role": {
            ".validate": "!data.exists() ? newData.val() === 'user' : (newData.val() === data.val() || root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin')"
          }
        }
      }
    },

    "usernames": {
      ".read": "auth != null",
      "$key": {
        ".write": "auth != null && ((!data.exists() && newData.val() === auth.uid) || data.val() === auth.uid || root.child('users').child(auth.uid).child('profile').child('role').val() === 'admin')",
        ".validate": "!newData.exists() || newData.isString()"
      }
    }
  }
}
